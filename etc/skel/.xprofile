# --- 2. Cấu hình cho các ứng dụng GTK (Thunar, Firefox, v.v.) ---
# Không dùng GDK_SCALE=2 vì nó sẽ ép mọi thứ to gấp đôi (200%)
export GDK_DPI_SCALE=1 

# --- 3. Cấu hình cho các ứng dụng Qt (VLC, OBS, KeepassXC) ---
export QT_AUTO_SCREEN_SCALE_FACTOR=1
# Nếu các app Qt vẫn nhỏ, hãy bỏ comment dòng dưới để ép scale 1.5
# export QT_SCREEN_SCALE_FACTORS=1.5

# --- 4. Cấu hình các bộ toolkit khác ---
export ELM_SCALE=1.5
export CLUTTER_SCALE=1.5
